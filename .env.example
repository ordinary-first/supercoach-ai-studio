# ============================================
# SuperCoach AI Studio — Environment Variables
# ============================================
# Copy to .env.local and fill in values

# --- AI Providers ---
OPENAI_API_KEY=                    # Required: OpenAI API key
ANTHROPIC_API_KEY=                 # Optional: Anthropic Claude API key

# --- Firebase ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=coach-52bf4.firebaseapp.com
FIREBASE_PROJECT_ID=coach-52bf4
FIREBASE_STORAGE_BUCKET=coach-52bf4.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_VAPID_KEY=

# --- Firebase Admin (Server-side only) ---
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CLIENT_EMAIL=

# --- Cloudflare R2 (S3 Compatible) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

# --- Polar (Payment) ---
POLAR_ACCESS_TOKEN=
POLAR_SERVER=sandbox
POLAR_SUCCESS_URL=https://secretcoach.ai
POLAR_WEBHOOK_SECRET=

# --- Optional ---
FAL_KEY=                           # Fal.ai (reserved for future use)
GOOGLE_API_KEY=                    # Legacy Google API key
